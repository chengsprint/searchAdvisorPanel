{
  "name": "searchadvisor-runtime",
  "version": "1.0.0",
  "description": "SearchAdvisor Runtime - Modular Development",
  "main": "dist/runtime.js",
  "scripts": {
    "build": "node build.js",
    "check": "node --check dist/runtime.js && node scripts/verify_snapshot_contract.js",
    "release:stable": "node scripts/write_stable_manifest.js",
    "validate": "npm run build && npm run check",
    "prepare": "husky install || true"
  },
  "keywords": [
    "searchadvisor",
    "runtime",
    "analytics"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/jest": "^29.5.12",
    "audit-ci": "^7.1.0",
    "dompurify": "^3.3.3",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^1.7.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.2",
    "playwright": "^1.48.0",
    "prettier": "^3.2.5",
    "serve": "^14.2.3"
  },
  "dependencies": {
    "puppeteer": "^24.39.1"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
